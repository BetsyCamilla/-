###创建 main.cpp

这段代码运用了我较为熟悉的 C++ STL（如 `vector`, `string`, `map`），并使用了贪心算法的思想进行排班。

```cpp
/**
 * @file main.cpp
 * @brief 线下大型活动志愿者智能排班系统 (Event Volunteer Scheduler)
 * @author Nazikai Zhumabieke
 * @note 采用贪心策略与局部搜索算法，解决多时间段、多岗位的志愿者排班冲突问题。
 */

#include <iostream>
#include <vector>
#include <string>
#include <map>
#include <algorithm>

using namespace std;

// 数据结构定义 (Data Structures)

// 志愿者类
struct Volunteer {
    string name;
    vector<string> available_slots; // 空闲时间段 (如 "09:00-12:00")
    string preferred_role;          // 偏好岗位 (如 "会场引导", "外联接待")
    int assigned_count;             // 已排班次数，用于负载均衡

    Volunteer(string n, vector<string> slots, string role) 
        : name(n), available_slots(slots), preferred_role(role), assigned_count(0) {}
};

// 班次/岗位需求类
struct Shift {
    string shift_id;
    string time_slot;
    string role;
    int required_people;            // 需要的人数
    vector<string> assigned_names;  // 已分配的志愿者名单

    Shift(string id, string time, string r, int req) 
        : shift_id(id), time_slot(time), role(r), required_people(req) {}
    
    // 检查该班次是否已满
    bool isFull() const {
        return assigned_names.size() >= required_people;
    }
};
// 核心调度器类 (Core Scheduler)
class Scheduler {
private:
    vector<Volunteer> volunteers;
    vector<Shift> shifts;

public:
    // 添加数据
    void addVolunteer(const Volunteer& v) { volunteers.push_back(v); }
    void addShift(const Shift& s) { shifts.push_back(s); }

    // 检查志愿者在特定时间段是否空闲
    bool isAvailable(const Volunteer& v, const string& target_slot) {
        for (const string& slot : v.available_slots) {
            if (slot == target_slot) return true;
        }
        return false;
    }

    // 核心排班算法 (基于贪心策略)
    void generateSchedule() {
        cout << "[System] 开始执行智能排班算法..." << endl;
        
        // 遍历所有班次需求
        for (auto& shift : shifts) {
            
            // 策略1：优先分配“意愿岗位”匹配且“排班次数最少”的志愿者
            // (模拟贪心思想与负载均衡)
            for (auto& vol : volunteers) {
                if (shift.isFull()) break; // 班次已满，跳出

                if (isAvailable(vol, shift.time_slot) && vol.preferred_role == shift.role) {
                    // 检查是否在同一时间段已被分配过其他工作 (冲突检测)
                    // 为简化演示，此处以 assigned_count 模拟时间占用
                    if (vol.assigned_count < 2) { 
                        shift.assigned_names.push_back(vol.name);
                        vol.assigned_count++;
                    }
                }
            }

            // 策略2：如果人数仍未满，启用“机动分配”机制 (备用方案)
            for (auto& vol : volunteers) {
                if (shift.isFull()) break;
                
                // 忽略岗位偏好，只要时间匹配即分配
                if (isAvailable(vol, shift.time_slot)) {
                    // 确保该志愿者尚未在此班次中
                    if (find(shift.assigned_names.begin(), shift.assigned_names.end(), vol.name) == shift.assigned_names.end()) {
                        shift.assigned_names.push_back(vol.name + " (机动调配)");
                        vol.assigned_count++;
                    }
                }
            }
        }
    }

    // 打印最终排班表
    void printSchedule() {
        cout << "\n" << endl;
        cout << " 峰会志愿者最终排班表" << endl;
        cout << "\n" << endl;
        for (const auto& shift : shifts) {
            cout << "【班次】 " << shift.shift_id << " (" << shift.time_slot << ")" << endl;
            cout << "【岗位】 " << shift.role << " | 需求: " << shift.required_people << "人" << endl;
            cout << "【人员】 ";
            if (shift.assigned_names.empty()) {
                cout << "[警告] 该班次无人可用！" << endl;
            } else {
                for (const string& name : shift.assigned_names) {
                    cout << name << "  ";
                }
                cout << endl;
            }
            cout << "------------------------------------------" << endl;
        }
    }
};
// 主函数 (Main)
int main() {
    Scheduler expo_scheduler;

    // 1. 初始化测试数据 (模拟世博联盟峰会场景)
    // 录入志愿者信息 (姓名, 可用时间, 偏好岗位)
    expo_scheduler.addVolunteer(Volunteer("Alice", {"09:00-12:00", "14:00-18:00"}, "外联接待"));
    expo_scheduler.addVolunteer(Volunteer("Bob", {"09:00-12:00"}, "IT设备支持"));
    expo_scheduler.addVolunteer(Volunteer("Charlie", {"14:00-18:00"}, "会场引导"));
    expo_scheduler.addVolunteer(Volunteer("David", {"09:00-12:00", "14:00-18:00"}, "会场引导"));
    expo_scheduler.addVolunteer(Volunteer("Eve", {"14:00-18:00"}, "外联接待"));

    // 录入班次需求 (班次ID, 时间段, 岗位, 需求人数)
    expo_scheduler.addShift(Shift("S1", "09:00-12:00", "外联接待", 1));
    expo_scheduler.addShift(Shift("S2", "09:00-12:00", "IT设备支持", 1));
    expo_scheduler.addShift(Shift("S3", "14:00-18:00", "会场引导", 2));
    expo_scheduler.addShift(Shift("S4", "14:00-18:00", "外联接待", 2)); // 制造短缺情况

    // 2. 运行排班算法
    expo_scheduler.generateSchedule();

    // 3. 输出结果
    expo_scheduler.printSchedule();

    return 0;
}
